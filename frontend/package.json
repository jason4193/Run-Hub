{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal frontend-only website that displays running logs from intervals.icu.",
  "scripts": {
    "copy-data": "node -e \"require('fs').cpSync('../data','public/data',{recursive:true})\"",
    "predev": "npm run copy-data",
    "dev": "vite",
    "prebuild": "npm run copy-data",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
