{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal frontend-only website that displays running logs from intervals.icu.",
  "scripts": {
    "copy-data": "node -e \"require('fs').cpSync('../data','public/data',{recursive:true})\"",
    "predev": "npm run copy-data",
    "dev": "vite",
    "prebuild": "npm run copy-data",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.4",
    "@deck.gl/geo-layers": "^9.3.4",
    "@deck.gl/layers": "^9.3.4",
    "@deck.gl/mapbox": "^9.3.4",
    "@deck.gl/react": "^9.3.4",
    "deck.gl": "^9.3.4",
    "gsap": "^3.15.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.0"
  }
}
